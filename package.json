{
    "name": "clio-mcp-server",
    "version": "1.1.0",
    "description": "MCP server integrating Claude.ai with Clio Manage API v4",
    "main": "dist/index.js",
    "scripts": {
        "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
        "build": "esbuild src/index.ts --bundle --platform=node --target=node18 --outfile=dist/index.js --external:express --external:axios --external:dotenv --external:zod --external:@modelcontextprotocol/sdk --external:docx --external:exceljs --external:jszip",
        "start": "npm run build && node dist/index.js"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.12.1",
        "axios": "^1.7.9",
        "docx": "^8.5.0",
        "dotenv": "^16.4.7",
        "esbuild": "^0.20.0",
        "exceljs": "^4.4.0",
        "express": "^4.21.2",
        "jszip": "^3.10.1",
        "zod": "^3.24.1"
    },
    "devDependencies": {
        "@types/express": "^5.0.0",
        "@types/node": "^22.10.5",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.7.3"
    }
}
