PORT=3000
CLIO_BASE_URL=https://app.clio.com
CLIO_API_BASE_URL=https://app.clio.com/api/v4
CLIO_CLIENT_ID=
CLIO_CLIENT_SECRET=
CLIO_REDIRECT_URI=http://localhost:3000/oauth/callback
CLIO_ACCESS_TOKEN=
CLIO_REFRESH_TOKEN=
ANTHROPIC_API_KEY=            # Required for /review AI-generated suggestions
REVIEW_PASSWORD=              # Password for /review UI (leave empty for no auth)
MCP_AUTH_TOKEN=               # REQUIRED: long random secret; clients send `Authorization: Bearer <token>` (or `?token=` on /sse)
MCP_ALLOWED_ORIGINS=          # Comma-separated list of allowed browser Origin headers (e.g. https://claude.ai). Non-browser clients don't send Origin.
